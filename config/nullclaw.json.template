{
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-sonnet-4-20250514"
      }
    }
  },
  "models": {
    "providers": {
      "anthropic": {
        "api_key": "${ANTHROPIC_API_KEY}"
      }
    }
  },
  "channels": {
    "imessage": {
      "enabled": true,
      "allow_from": ["*"],
      "poll_interval_secs": 3
    },
    "email": {
      "enabled": true,
      "smtp_host": "${SMTP_HOST}",
      "smtp_port": ${SMTP_PORT},
      "smtp_user": "${SMTP_USER}",
      "smtp_password": "${SMTP_PASSWORD}",
      "from_address": "${EMAIL_FROM}",
      "allow_from": ["*"]
    },
    "slack": [{
      "bot_token": "${SLACK_BOT_TOKEN}",
      "channel_id": "${SLACK_CHANNEL_ID}",
      "mode": "http"
    }],
    "twitter": [{
      "bearer_token": "${TWITTER_BEARER_TOKEN}"
    }]
  },
  "memory": {
    "backend": "sqlite",
    "auto_save": true
  },
  "gateway": {
    "port": 3000,
    "host": "127.0.0.1",
    "require_pairing": true
  },
  "tools": {
    "message_history": {
      "enabled": true
    }
  }
}
